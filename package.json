{
  "name": "ya-kansuji",
  "version": "1.1.0",
  "description": "Yet another Japanese kansuji library — converts Japanese numerals (漢数字・大字・全角) to/from numbers",
  "keywords": [
    "kansuji",
    "japanese",
    "numeral",
    "漢数字",
    "大字"
  ],
  "license": "MIT",
  "author": "Tatsuki Sugiura <sugi@nemui.org>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.iife.min.js",
  "jsdelivr": "./dist/index.iife.min.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsdown",
    "pretest": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm test && npx publint && npx @arethetypeswrong/cli --pack .",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "^0.3.21",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "unrun": "^0.3.1",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sugi/ya-kansuji-js.git"
  },
  "bugs": {
    "url": "https://github.com/sugi/ya-kansuji-js/issues"
  },
  "homepage": "https://github.com/sugi/ya-kansuji-js#readme"
}
